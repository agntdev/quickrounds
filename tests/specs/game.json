[
  {
    "name": "/game starts a new game round with join button",
    "steps": [
      {
        "send": { "text": "/game", "chatId": 10, "userId": 10 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🎮 Game round!\n\nPlayers (0/6):\nNo players yet — tap ✋ Join to enter.\n\n⏳ Registration closes in 30s"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Join game deducts points and adds user to player list",
    "steps": [
      {
        "send": { "text": "/game", "chatId": 20, "userId": 20 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🎮 Game round!\n\nPlayers (0/6):\nNo players yet — tap ✋ Join to enter.\n\n⏳ Registration closes in 30s"
            }
          }
        ]
      },
      {
        "send": { "callback": "game:join", "chatId": 20, "userId": 21, "messageId": 1001 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "🎮 Game round!\n\nPlayers (1/6):\n1. Player 21\n\n⏳ Registration closes in 30s"
            }
          },
          { "method": "answerCallbackQuery" }
        ]
      }
    ]
  },
  {
    "name": "Start now cancels game with fewer than two players and refunds",
    "steps": [
      {
        "send": { "text": "/game", "chatId": 30, "userId": 30 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🎮 Game round!\n\nPlayers (0/6):\nNo players yet — tap ✋ Join to enter.\n\n⏳ Registration closes in 30s"
            }
          }
        ]
      },
      {
        "send": { "callback": "game:join", "chatId": 30, "userId": 31, "messageId": 1001 },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "🎮 Game round!\n\nPlayers (1/6):\n1. Player 31\n\n⏳ Registration closes in 30s"
            }
          },
          { "method": "answerCallbackQuery" }
        ]
      },
      {
        "send": { "callback": "game:start", "chatId": 30, "userId": 30, "messageId": 1001 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "The game round was cancelled and your 10 points have been refunded."
            }
          },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Game cancelled — need at least 2 players to start. All join fees have been refunded."
            }
          },
          { "method": "answerCallbackQuery" }
        ]
      }
    ]
  },
